# GNOME Terminal profile - NebulaOS
# Import with: dconf load /org/gnome/terminal/legacy/profiles:/:b0004596-520f-4e3a-b7e0-2e3b9e5a3054/ < nebula-terminal.profile

[/]
visible-name='NebulaOS'
use-theme-colors=false
foreground-color='#e2d9f3'
background-color='#0f0a1a'
bold-color-same-as-fg=false
bold-color='#c4b5fd'
cursor-colors-set=true
cursor-foreground-color='#e2d9f3'
cursor-background-color='#7c3aed'
highlight-colors-set=true
highlight-foreground-color='#0f0a1a'
highlight-background-color='#7c3aed'
audible-bell=false
scrollbar-policy='never'
font='Ubuntu Mono 12'
use-system-font=false
allow-bold=true
use-transparent-background=false
scrollbar-background-color='rgba(124,58,237,0.4)'
scrollbar-foreground-color='rgba(196,181,253,0.7)'
background-color-foreground='#e2d9f3'
